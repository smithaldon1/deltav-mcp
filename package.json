{
  "name": "deltav-edge-mcp-server",
  "version": "0.1.0",
  "description": "Safety-conscious MCP server for Emerson DeltaV Edge read-only data access and offline engineering package generation.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "deltav-edge-mcp-server": "dist/index.js"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build:server": "tsc -p tsconfig.json",
    "build:mock": "npm run build -w mock-deltav-edge",
    "build:mock-ui": "npm run build -w mock-deltav-edge-ui",
    "dev": "tsx watch src/index.ts",
    "dev:mock": "npm run dev -w mock-deltav-edge",
    "build": "npm run build:server && npm run build:mock",
    "start": "node dist/index.js",
    "start:mock": "npm run start -w mock-deltav-edge",
    "test": "npm run build:mock && vitest run",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "workspaces": [
    "mock-deltav-edge",
    "mock-deltav-edge/ui"
  ],
  "keywords": [
    "mcp",
    "deltav",
    "industrial-automation",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^16.4.5",
    "undici": "^7.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@types/node": "^22.10.1",
    "eslint": "^9.12.0",
    "globals": "^15.11.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.8.1",
    "vitest": "^2.1.2"
  }
}
